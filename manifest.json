{
  "manifest_version": 3,

  "name": "Smart Tab Organizer",

  "description": "Automatically organize and rediscover browser tabs.",

  "version": "1.0.0",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}